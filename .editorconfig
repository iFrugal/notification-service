# EditorConfig — https://editorconfig.org
# Keeps whitespace, line endings, and charset consistent across IDEs
# and OSes so formatting churn doesn't pollute diffs.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{java,xml,yml,yaml,json,md,properties,ftl}]
indent_size = 4

[*.{yml,yaml,json,md}]
indent_size = 2

[*.md]
# Preserve trailing-whitespace line-break semantics in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
